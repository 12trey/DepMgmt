@{
    ##================================================
    ## PSAppDeployToolkit v4.x Configuration
    ## Generated by AIPSADT for: {{appName}} v{{version}}
    ##================================================

    Toolkit = @{
        ## Logging
        LogPath              = "$env:WinDir\Logs\Software"
        LogMaxSize           = 10
        CompressLogs         = $true
        LogWriteToHost       = $true
        LogDebugMessage      = $false

        ## Temp Path
        TempPath             = "$env:Temp"
        TempPathNoCleanup    = $false

        ## Registry
        RegPath              = 'HKLM:\SOFTWARE\PSAppDeployToolkit'
    }

    MSI = @{
        LogPath              = "$env:WinDir\Logs\Software"
        LoggingOptions       = '/L*V'
        InstallParams        = '/QN /NORESTART'
        SilentParams         = '/QN /NORESTART'
        UninstallParams      = '/QN /NORESTART'
    }

    UI = @{
        BalloonNotifications = $true
        DialogTimeout        = 6600
        PromptPersistInterval = 60
        RestartPromptTimeout = 600
        LanguageOverride     = ''
        DeferDeadline        = ''
    }
}
