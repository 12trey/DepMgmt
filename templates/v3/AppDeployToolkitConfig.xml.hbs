<?xml version="1.0" encoding="utf-8"?>
<AppDeployToolkit_Config>
    <Toolkit_Options>
        <Toolkit_Name>PSAppDeployToolkit</Toolkit_Name>
        <Toolkit_TempPath>$envTemp</Toolkit_TempPath>
        <Toolkit_RegPath>HKLM:\SOFTWARE\PSAppDeployToolkit</Toolkit_RegPath>
        <Toolkit_LogPath>$envWinDir\Logs\Software</Toolkit_LogPath>
        <Toolkit_CompressLogs>true</Toolkit_CompressLogs>
        <Toolkit_LogMaxSize>10</Toolkit_LogMaxSize>
        <Toolkit_LogWriteToHost>true</Toolkit_LogWriteToHost>
    </Toolkit_Options>
    <MSI_Options>
        <MSI_LogPath>$envWinDir\Logs\Software</MSI_LogPath>
        <MSI_LoggingOptions>/L*V</MSI_LoggingOptions>
        <MSI_InstallParams>/QN /NORESTART</MSI_InstallParams>
        <MSI_UninstallParams>/QN /NORESTART</MSI_UninstallParams>
    </MSI_Options>
    <UI_Options>
        <InstallationUI_LanguageOverride></InstallationUI_LanguageOverride>
        <ShowBalloonNotifications>true</ShowBalloonNotifications>
        <InstallationUI_Timeout>6600</InstallationUI_Timeout>
        <InstallationPrompt_PersistInterval>60</InstallationPrompt_PersistInterval>
        <InstallationRestartPrompt_Timeout>600</InstallationRestartPrompt_Timeout>
        <InstallationDefer_Deadline></InstallationDefer_Deadline>
    </UI_Options>
</AppDeployToolkit_Config>
