<#
.SYNOPSIS
    PSAppDeployToolkit v3 - Deploy Application
.DESCRIPTION
    Generated by AIPSADT for: {{appName}} v{{version}}
    Vendor: {{vendor}}
    PSADT Version: 3.x
.NOTES
    Generated on: {{createdAt}}
#>

[CmdletBinding()]
Param (
    [Parameter(Mandatory=$false)]
    [ValidateSet('Install','Uninstall','Repair')]
    [string]$DeploymentType = 'Install',
    [Parameter(Mandatory=$false)]
    [ValidateSet('Interactive','Silent','NonInteractive')]
    [string]$DeployMode = 'Interactive',
    [Parameter(Mandatory=$false)]
    [switch]$AllowRebootPassThru = $false,
    [Parameter(Mandatory=$false)]
    [switch]$TerminalServerMode = $false,
    [Parameter(Mandatory=$false)]
    [switch]$DisableLogging = $false
)

Try {
    ## Set the script execution policy for this process
    Try { Set-ExecutionPolicy -ExecutionPolicy 'ByPass' -Scope 'Process' -Force -ErrorAction 'Stop' } Catch {}

    ##*===============================================
    ##* VARIABLE DECLARATION
    ##*===============================================
    ## Variables: Application
    [string]$appVendor = '{{vendor}}'
    [string]$appName = '{{appName}}'
    [string]$appVersion = '{{version}}'
    [string]$appArch = '{{#if architecture}}{{architecture}}{{else}}x64{{/if}}'
    [string]$appLang = 'EN'
    [string]$appRevision = '01'
    [string]$appScriptVersion = '1.0.0'
    [string]$appScriptDate = '{{createdAt}}'
    [string]$appScriptAuthor = 'AIPSADT'

    ## Variables: Install Titles (for PSADT UI prompts)
    [string]$installTitle = "$appVendor $appName $appVersion"

    ##*===============================================
    ##* ANCHOR: PSADT v3 INITIALIZATION
    ##*===============================================
    ## Dot source the AppDeployToolkitMain.ps1 script
    [string]$scriptDirectory = Split-Path -Path $MyInvocation.MyCommand.Definition -Parent
    [string]$appDeployToolkitMain = "$scriptDirectory\AppDeployToolkit\AppDeployToolkitMain.ps1"
    If (Test-Path -LiteralPath $appDeployToolkitMain -PathType 'Leaf') {
        . $appDeployToolkitMain
    } Else {
        Write-Host "PSADT toolkit not found at: $appDeployToolkitMain"
        Write-Host "Running in standalone mode..."
    }
    ##*===============================================

    ##*===============================================
    ##* PRE-INSTALLATION
    ##*===============================================
    If ($DeploymentType -ine 'Uninstall' -and $DeploymentType -ine 'Repair') {
        [string]$installPhase = 'Pre-Installation'

        ## Show Welcome Message, close processes if required
        {{#if closeApps}}
        Show-InstallationWelcome -CloseApps '{{closeApps}}' -CheckDiskSpace -PersistPrompt
        {{else}}
        Show-InstallationWelcome -CheckDiskSpace
        {{/if}}

        ## Show Progress Message
        Show-InstallationProgress

        {{#each preInstallSteps}}
        ## Pre-install step: {{this.description}}
        {{{this.command}}}
        {{/each}}
    }

    ##*===============================================
    ##* INSTALLATION
    ##*===============================================
    If ($DeploymentType -ine 'Uninstall' -and $DeploymentType -ine 'Repair') {
        [string]$installPhase = 'Installation'

        {{#if installCommand}}
        ## Execute installation
        {{{installCommand}}}
        {{else}}
        ## No install command specified
        {{/if}}
    }

    ##*===============================================
    ##* POST-INSTALLATION
    ##*===============================================
    If ($DeploymentType -ine 'Uninstall' -and $DeploymentType -ine 'Repair') {
        [string]$installPhase = 'Post-Installation'

        {{#each postInstallSteps}}
        ## Post-install step: {{this.description}}
        {{{this.command}}}
        {{/each}}

        ## Display a message at the end of the install
        Show-InstallationPrompt -Message "$appName $appVersion installation complete." -ButtonRightText 'OK' -Icon Information -NoWait
    }

    ##*===============================================
    ##* UNINSTALLATION
    ##*===============================================
    If ($DeploymentType -ieq 'Uninstall') {
        [string]$installPhase = 'Uninstallation'

        ## Show Welcome Message, close processes
        {{#if closeApps}}
        Show-InstallationWelcome -CloseApps '{{closeApps}}'
        {{else}}
        Show-InstallationWelcome
        {{/if}}

        ## Show Progress Message
        Show-InstallationProgress

        {{#if uninstallCommand}}
        {{{uninstallCommand}}}
        {{else}}
        ## No uninstall command specified
        {{/if}}
    }

    ##*===============================================
    ##* REPAIR
    ##*===============================================
    If ($DeploymentType -ieq 'Repair') {
        [string]$installPhase = 'Repair'

        ## Show Progress Message
        Show-InstallationProgress

        {{#if repairCommand}}
        {{{repairCommand}}}
        {{else}}
        ## No repair command specified
        {{/if}}
    }

    ##*===============================================
    ##* END SCRIPT BODY
    ##*===============================================

    ## Call the Exit-Script function to perform final cleanup operations
    Exit-Script -ExitCode $mainExitCode

} Catch {
    [int32]$mainExitCode = 60001
    [string]$mainErrorMessage = "$(Resolve-Error)"
    Write-Log -Message $mainErrorMessage -Severity 3 -Source $deployAppScriptFriendlyName
    Show-DialogBox -Text $mainErrorMessage -Icon 'Stop'
    Exit-Script -ExitCode $mainExitCode
}
