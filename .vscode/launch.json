{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to main",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode-ext"
            ],
            "name": "Launch Extension",
            "outFiles": [
                "${workspaceFolder}/vscode-ext/out/**/*.js"
            ],
            //"preLaunchTask": "npm",
            "request": "launch",
            "type": "extensionHost"
        },
        {
            "name": "PSADT client Attach Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}/client"
        },
        {
            "name": "logviewer Attach Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}/server/logviewer/reactpublic/logviewer/src"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Logviewer",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/server/logviewer/reactpublic/logviewer/src"
        },
        {
            "name": "Attach by Process ID",
            "processId": "${command:PickProcess}",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Attach",
            "port": 9229,
            "request": "attach",
            "cwd": "${workspaceFolder}",
            // "sourceMaps": true,
            // "outFiles": [
            //     "${workspaceFolder}/dist/**/*.js",
            //     "${workspaceFolder}/client/dist/**/*.js"
            // ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Debug Main Process",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
            "windows": {
                "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
            },
            "args": [
                "."
            ],
            "outputCapture": "std"
        }
    ]
}